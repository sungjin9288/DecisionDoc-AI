# ── Provider Selection ──────────────────────────────────────────────────────
# Options: openai | gemini | local | mock
# Comma-separated for fallback chains: "openai,gemini"
DECISIONDOC_PROVIDER=mock

# ── Environment ──────────────────────────────────────────────────────────────
# Options: dev | prod (prod requires DECISIONDOC_API_KEY to be set)
DECISIONDOC_ENV=dev

# ── API Keys (auth middleware) ───────────────────────────────────────────────
DECISIONDOC_API_KEY=
DECISIONDOC_API_KEYS=
DECISIONDOC_OPS_KEY=your-ops-key

# ── Maintenance mode ─────────────────────────────────────────────────────────
DECISIONDOC_MAINTENANCE=0

# ── Public Procurement Go/No-Go Copilot ─────────────────────────────────────
# Set to 1 to expose project-scoped procurement attach/evaluate/recommend UI and APIs.
DECISIONDOC_PROCUREMENT_COPILOT_ENABLED=0

# ── CORS ─────────────────────────────────────────────────────────────────────
DECISIONDOC_CORS_ENABLED=0
DECISIONDOC_CORS_ALLOW_ORIGINS=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DECISIONDOC_OPENAI_MODEL=gpt-4o-mini
DECISIONDOC_MAX_OUTPUT_TOKENS=8192
DECISIONDOC_PROVIDER_TIMEOUT=120

# ── Google Gemini ─────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIza...
DECISIONDOC_GEMINI_MODEL=gemini-2.0-flash

# ── Local LLM (Ollama / vLLM / LM Studio / LocalAI) ─────────────────────────
# Set DECISIONDOC_PROVIDER=local to use a local model instead of cloud APIs.
# Any OpenAI-compatible server is supported.
LOCAL_LLM_BASE_URL=http://localhost:11434/v1
LOCAL_LLM_MODEL=llama3.1:8b
LOCAL_LLM_API_KEY=local
LOCAL_LLM_TIMEOUT=300

# ── Storage ───────────────────────────────────────────────────────────────────
# Options: local | s3
DECISIONDOC_STORAGE=local
DATA_DIR=./data
EXPORT_DIR=./data
DECISIONDOC_CACHE_ENABLED=0
DECISIONDOC_CACHE_TTL_HOURS=24

# ── S3 (required when DECISIONDOC_STORAGE=s3) ────────────────────────────────
DECISIONDOC_S3_BUCKET=my-bucket
DECISIONDOC_S3_PREFIX=decisiondoc-ai/
AWS_REGION=ap-northeast-2

# ── Template ──────────────────────────────────────────────────────────────────
DECISIONDOC_TEMPLATE_VERSION=v1

# ── Generation ────────────────────────────────────────────────────────────────
LOW_QUALITY_THRESHOLD=0.6
MAX_RETRY_ATTEMPTS=2
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF_SECONDS=1,3,7

# ── Self-improvement ──────────────────────────────────────────────────────────
LOW_RATING_THRESHOLD=3
FINETUNE_MIN_RATING=4
FINETUNE_MIN_SCORE=0.85
FINETUNE_AUTO_THRESHOLD=50
FINETUNE_BASE_MODEL=gpt-4o-mini
FINETUNE_PROMOTION_THRESHOLD=0.05

# ── Bundle auto-expansion ─────────────────────────────────────────────────────
AUTO_EXPAND_THRESHOLD=5

# ── Web Search (sketch endpoint enrichment) ───────────────────────────────────
# Set DECISIONDOC_SEARCH_ENABLED=1 to enable search context injection.
DECISIONDOC_SEARCH_ENABLED=0
SERPER_API_KEY=
BRAVE_API_KEY=
TAVILY_API_KEY=

# ── 나라장터 G2B API ──────────────────────────────────────────────────────────
# 발급: https://www.data.go.kr → "나라장터 입찰공고정보서비스" 검색
# API 키 없이도 URL 스크래핑(Playwright) 방식으로 공고 전문 수집 가능
G2B_API_KEY=
G2B_SEARCH_DAYS=7
G2B_MAX_RESULTS=20

# ── Voice Brief import ────────────────────────────────────────────────────────
# Leave VOICE_BRIEF_API_BASE_URL empty to disable project-level Voice Brief import.
VOICE_BRIEF_API_BASE_URL=
VOICE_BRIEF_API_BEARER_TOKEN=
VOICE_BRIEF_TIMEOUT_SECONDS=10.0

# ── Native meeting recording / transcription ─────────────────────────────────
# Upload a meeting recording, transcribe it with OpenAI, then generate
# `meeting_minutes_kr` / `project_report_kr` from the approved transcript.
# Leave OPENAI_API_KEY empty to keep transcription disabled in this runtime.
OPENAI_API_BASE_URL=https://api.openai.com/v1
MEETING_RECORDING_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
MEETING_RECORDING_MAX_UPLOAD_BYTES=26214400
MEETING_RECORDING_CONTEXT_CHAR_LIMIT=12000

# ── Eval (LLM-as-judge) ───────────────────────────────────────────────────────
DECISIONDOC_LLM_JUDGE_MODEL=gpt-4o-mini

# ── Ops / Observability ───────────────────────────────────────────────────────
DECISIONDOC_LOG_LEVEL=INFO
DECISIONDOC_HTTP_API_ID=
DECISIONDOC_LAMBDA_FUNCTION_NAME=
DECISIONDOC_INVESTIGATE_DEDUP_TTL_SECONDS=300
DECISIONDOC_INVESTIGATE_BUCKET_SECONDS=300
DECISIONDOC_INVESTIGATE_STATUSPAGE_UPDATE_MIN_SECONDS=600
DECISIONDOC_OPS_STATUSPAGE_STRICT=0

# ── Status page integration ───────────────────────────────────────────────────
STATUSPAGE_PAGE_ID=
STATUSPAGE_API_KEY=

# ── 인증 (JWT) ────────────────────────────────────────────────────────────────
# openssl rand -hex 32 로 생성
JWT_SECRET_KEY=your-secret-key-here
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── 이메일 알림 (SMTP) ─────────────────────────────────────────────────────────
# Gmail 예시: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=you@gmail.com
# 앱 비밀번호: https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Slack 알림 ──────────────────────────────────────────────────────────────
# Slack Incoming Webhook URL (https://api.slack.com/messaging/webhooks)
SLACK_WEBHOOK_URL=

# ── Multi-tenant ──────────────────────────────────────────────────────────────
# Tenants are resolved via the X-Tenant-ID request header.
# Default tenant is "system" when header is absent.

# ── Stripe 결제 ──────────────────────────────────────
# Stripe 대시보드 → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Stripe 대시보드 → Webhooks → 서명 시크릿
STRIPE_WEBHOOK_SECRET=whsec_...

# ── 서버 환경 ──────────────────────────────────────
# "production" disables Swagger UI and enforces security checks
ENVIRONMENT=development

# ── CORS ───────────────────────────────────────────
# 프로덕션: 실제 도메인으로 변경
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Ops / CloudWatch ──────────────────────────────────────────────────────
# AWS CloudWatch log group for ops investigation
DECISIONDOC_LOG_GROUP=

# AWS Lambda function name (if deployed as Lambda)
AWS_LAMBDA_FUNCTION_NAME=

# ── SSO Encryption ────────────────────────────────────────────────────────
# AES-256 key for SSO secret encryption (default: derived from JWT_SECRET_KEY)
# Set separately for key rotation independence
SSO_ENCRYPTION_KEY=

# ── LLM Prompt ────────────────────────────────────────────────────────────
# Prompt variant selector for A/B testing (e.g. 'v2', 'concise')
DECISIONDOC_PROMPT_VARIANT=
