# Copy this file to a local-only file such as `.github-actions.env`
# and fill in the real values before running the helper scripts below:
#   bash scripts/import-github-actions-env-file.sh --stage dev --source .env
#   bash scripts/check-github-actions-config.sh --stage dev --env-file .github-actions.env --procurement-smoke --voice-brief --voice-brief-smoke
#   bash scripts/apply-github-actions-config.sh --stage dev --env-file .github-actions.env --procurement-smoke --voice-brief --voice-brief-smoke

# ── Common repository secrets ────────────────────────────────────────────────
AWS_REGION=ap-northeast-2
DECISIONDOC_API_KEY=
DECISIONDOC_OPS_KEY=
# Optional: only required when automated Statuspage incident posting is enabled
STATUSPAGE_PAGE_ID=
STATUSPAGE_API_KEY=

# ── DEV stage secrets ────────────────────────────────────────────────────────
AWS_ROLE_ARN_DEV=
DECISIONDOC_S3_BUCKET_DEV=
G2B_API_KEY_DEV=
PROCUREMENT_SMOKE_USERNAME_DEV=
PROCUREMENT_SMOKE_PASSWORD_DEV=
VOICE_BRIEF_API_BASE_URL_DEV=
VOICE_BRIEF_API_BEARER_TOKEN_DEV=
VOICE_BRIEF_SMOKE_USERNAME_DEV=
VOICE_BRIEF_SMOKE_PASSWORD_DEV=

# ── DEV stage variables ──────────────────────────────────────────────────────
DECISIONDOC_PROCUREMENT_COPILOT_ENABLED_DEV=0
# Optional stable procurement smoke fixture. Leave blank to let smoke auto-discover a recent live G2B opportunity.
PROCUREMENT_SMOKE_URL_OR_NUMBER_DEV=
PROCUREMENT_SMOKE_TENANT_ID_DEV=
VOICE_BRIEF_TIMEOUT_SECONDS_DEV=10.0
VOICE_BRIEF_SMOKE_RECORDING_ID_DEV=
VOICE_BRIEF_SMOKE_REVISION_ID_DEV=
VOICE_BRIEF_SMOKE_TENANT_ID_DEV=

# ── PROD stage secrets ───────────────────────────────────────────────────────
AWS_ROLE_ARN_PROD=
DECISIONDOC_S3_BUCKET_PROD=
G2B_API_KEY_PROD=
PROCUREMENT_SMOKE_USERNAME_PROD=
PROCUREMENT_SMOKE_PASSWORD_PROD=
VOICE_BRIEF_API_BASE_URL_PROD=
VOICE_BRIEF_API_BEARER_TOKEN_PROD=
VOICE_BRIEF_SMOKE_USERNAME_PROD=
VOICE_BRIEF_SMOKE_PASSWORD_PROD=

# ── PROD stage variables ─────────────────────────────────────────────────────
DECISIONDOC_PROCUREMENT_COPILOT_ENABLED_PROD=0
# Optional stable procurement smoke fixture. Leave blank to let smoke auto-discover a recent live G2B opportunity.
PROCUREMENT_SMOKE_URL_OR_NUMBER_PROD=
PROCUREMENT_SMOKE_TENANT_ID_PROD=
VOICE_BRIEF_TIMEOUT_SECONDS_PROD=10.0
VOICE_BRIEF_SMOKE_RECORDING_ID_PROD=
VOICE_BRIEF_SMOKE_REVISION_ID_PROD=
VOICE_BRIEF_SMOKE_TENANT_ID_PROD=
